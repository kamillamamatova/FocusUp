# ── Server ────────────────────────────────────────────────
PORT=3001

# ── Session ────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_random_32_byte_hex_string

# ── Notion OAuth app credentials ──────────────────────────
# Create an integration at https://www.notion.so/profile/integrations
# Set type to "Public" and enable OAuth
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# The URL Notion will redirect to after the user authorises.
# Must match exactly what is registered in your Notion integration settings.
NOTION_REDIRECT_URI=http://localhost:3001/api/auth/notion/callback

# ── CORS ──────────────────────────────────────────────────
# Origin(s) allowed to call this API (comma-separated for multiple).
# In production this should be your hosted frontend URL.
FRONTEND_URL=http://localhost:5500

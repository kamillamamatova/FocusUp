# ── Server ────────────────────────────────────────────────
PORT=3001

# ── Email (password reset) ────────────────────────────────
# All four SMTP vars must be set to enable email delivery.
# If left blank, reset links are printed to the server console instead
# (useful in local dev — just copy the link from the terminal).
#
# Gmail example (use an App Password, not your account password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx   ← 16-char App Password
#
# Other services: Resend, Mailgun, SendGrid all provide SMTP credentials.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# "From" address shown to recipients. Defaults to SMTP_USER if not set.
SMTP_FROM=FocusUp <noreply@yourdomain.com>

# Path where focusup.db is stored.
# On Render: set to your persistent disk mount path, e.g. /var/data
# Leave unset for local dev (defaults to backend/data/).
DATA_PATH=

# Set to "production" on your hosting platform.
# This activates: secure cookies, strict CORS, trust proxy, sanitised error responses.
NODE_ENV=development

# ── Session ────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_random_32_byte_hex_string

# ── Notion OAuth app credentials ──────────────────────────
# Create a Public integration at https://www.notion.so/profile/integrations
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Must match exactly what is registered in your Notion integration settings.
# For local dev: http://localhost:3001/api/auth/notion/callback
# For production: https://your-backend.example.com/api/auth/notion/callback
NOTION_REDIRECT_URI=http://localhost:3001/api/auth/notion/callback

# ── CORS / redirect target ────────────────────────────────
# Origin(s) allowed to call this API. The first value is also used as the
# OAuth redirect target. Comma-separate multiple origins if needed.
#
# Local dev examples:
#   VS Code Live Server  → http://localhost:5500
#   Python http.server   → http://localhost:8080
#   Netlify dev          → http://localhost:8888
#
# Production: set this to your hosted frontend URL.
FRONTEND_URL=http://localhost:5500

# ── Production checklist ──────────────────────────────────
# Before deploying:
#
# 1. NODE_ENV=production
#    Enables secure cookies (HTTPS only) and strict CORS.
#
# 2. trust proxy
#    Automatically enabled when NODE_ENV=production.
#    Required on Railway, Render, Heroku, Fly.io — any platform that
#    terminates TLS before your app.  Without it, session cookies are
#    never sent because req.secure is always false.
#
# 3. SESSION_SECRET
#    Use a strong, unique random value. Never commit it.
#
# 4. Session store
#    The default MemoryStore loses sessions on restart and doesn't scale.
#    Install connect-redis and point it at a Redis instance for production.
#    See: https://www.npmjs.com/package/connect-redis
#
# 5. Token encryption at rest (optional but recommended)
#    Access tokens are stored in plaintext in backend/data/focusup.db.
#    Add AES-256-GCM encryption using a TOKEN_ENCRYPTION_KEY env var before
#    going to production if data-at-rest security is a requirement.
#
# 6. Rate limiting
#    Add express-rate-limit to the OAuth callback and sync endpoints to
#    prevent abuse. Suggested: 20 req/min per IP on /api/auth/*, 60/min on /api/sync.
#    See: https://www.npmjs.com/package/express-rate-limit
#
# ── Notion iframe / SameSite cookie limitation ────────────
# When the frontend is embedded in a Notion page via /embed, it runs inside
# a cross-site iframe.  Browsers block SameSite=Lax cookies in cross-site
# iframes, so the session cookie will not be sent for requests from the embed.
#
# The OAuth flow (Connect Notion button) opens a new browser tab/window,
# which is NOT cross-site, so it works correctly.  The problem is that after
# the user returns to the Notion page, API calls from inside the iframe
# (status check, sync) won't carry the session cookie.
#
# Mitigations to evaluate:
#   a) SameSite=None + Secure=true — allows cross-site cookies but requires
#      HTTPS and exposes the session to all cross-site requests.
#   b) Open a companion tab for API calls (complex UX).
#   c) Host the frontend on its own domain and open it standalone, using
#      Notion only as a link, not an embed.
#
# This is a known limitation of browser security policy and is not specific
# to this codebase.

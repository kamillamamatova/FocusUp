# ── Server ────────────────────────────────────────────────
PORT=3001

# ── Session ────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_random_32_byte_hex_string

# ── Notion OAuth app credentials ──────────────────────────
# Create a Public integration at https://www.notion.so/profile/integrations
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Must match exactly what is registered in your Notion integration settings.
# For local dev: http://localhost:3001/api/auth/notion/callback
NOTION_REDIRECT_URI=http://localhost:3001/api/auth/notion/callback

# ── CORS / redirect target ────────────────────────────────
# The origin of your frontend. After OAuth, the backend redirects here.
# Comma-separate multiple origins if needed.
# For local dev with VS Code Live Server: http://localhost:5500
# For local dev with a simple file server: http://localhost:8080
FRONTEND_URL=http://localhost:5500

# ── Production notes ──────────────────────────────────────
# NODE_ENV=production          activates secure cookies (requires HTTPS)
# SESSION_SECRET               must be a strong random value, never committed
# NOTION_CLIENT_SECRET         never exposed to the browser
# Tokens are stored in backend/data/focusup.db (plaintext for now).
#   Before going to production, add AES-256-GCM encryption for the
#   access_token column using a TOKEN_ENCRYPTION_KEY env var.
